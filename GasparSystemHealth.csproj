<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>GasparSystemHealth</AssemblyName>
    <RootNamespace>GasparSystemHealth</RootNamespace>
    <Company>Gaspar System Health</Company>
    <Product>Gaspar System Health</Product>
    <Description>Desktop tool for Windows diagnostics, security checks, updates, storage, network analysis, and hardware monitoring.</Description>
    <Version>1.0.6</Version>
    <FileVersion>1.0.6.0</FileVersion>
    <AssemblyVersion>1.0.6.0</AssemblyVersion>
    <InformationalVersion>1.0.6</InformationalVersion>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

</Project>
