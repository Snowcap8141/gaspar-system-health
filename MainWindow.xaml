<Window x:Class="GasparSystemHealth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gaspar System Health"
        Height="860"
        Width="1540"
        MinHeight="700"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#101116"
        Foreground="White"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#1A1C24" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2A2D39" />
        <SolidColorBrush x:Key="AccentBrush" Color="#19C2FF" />
        <SolidColorBrush x:Key="GoodBrush" Color="#22D67A" />
        <SolidColorBrush x:Key="WarnBrush" Color="#FFB830" />
        <SolidColorBrush x:Key="BadBrush" Color="#FF5C7A" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="MetricTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B5BDCC" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,2,0,1" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#151822" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1F3344" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#55D4FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#19C2FF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#19C2FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F3344" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#55D4FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#19C2FF" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#19C2FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#D0D5DD" />
            <Setter Property="Background" Value="#141823" />
            <Setter Property="BorderBrush" Value="#2A2D39" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#203246" />
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="#4BCFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#19C2FF" />
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="#19C2FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#203246" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#4BCFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#19C2FF" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#19C2FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0F1117" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Window.Resources>

    <Grid Margin="7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="GASPAR SYSTEM HEALTH"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center" />

            <Border Grid.Column="1"
                    Background="#18202B"
                    BorderBrush="{StaticResource GoodBrush}"
                    BorderThickness="1"
                    CornerRadius="13"
                    Padding="9,5">
                <StackPanel>
                    <TextBlock x:Name="RunModeText"
                               Text="AMMINISTRATORE"
                               Foreground="{StaticResource GoodBrush}"
                               FontWeight="Bold"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="ClockText"
                               Text="--:--:--"
                               Margin="0,2,0,0"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="2">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,7,7">
                <StackPanel>
                    <TextBlock Text="PC" Style="{StaticResource MetricTitleStyle}" />
                    <TextBlock x:Name="ComputerNameText" Text="-" Style="{StaticResource MetricValueStyle}" FontSize="14" />
                    <TextBlock x:Name="OperatingSystemText" Text="-" Foreground="#C7CDD8" TextWrapping="Wrap" FontSize="12" />
                    <TextBlock x:Name="GpuNameText" Text="-" Margin="0,2,0,0" Foreground="#C7CDD8" TextWrapping="Wrap" FontSize="12" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,7">
                <StackPanel>
                    <TextBlock Text="CPU" Style="{StaticResource MetricTitleStyle}" />
                    <TextBlock x:Name="CpuNameText" Text="-" Style="{StaticResource MetricValueStyle}" FontSize="14" />
                    <ProgressBar x:Name="CpuUsageBar" Height="7" Maximum="100" Value="0" Foreground="{StaticResource AccentBrush}" Background="#262A35" />
                    <TextBlock x:Name="CpuUsageText" Text="0%" Margin="0,3,0,0" Foreground="#D0D5DD" FontSize="11" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,7,7">
                <StackPanel>
                    <TextBlock Text="MEMORIA" Style="{StaticResource MetricTitleStyle}" />
                    <TextBlock x:Name="MemoryText" Text="-" Style="{StaticResource MetricValueStyle}" />
                    <ProgressBar x:Name="MemoryUsageBar" Height="7" Maximum="100" Value="0" Foreground="{StaticResource GoodBrush}" Background="#262A35" />
                    <TextBlock x:Name="UptimeText" Text="Online da -" Margin="0,3,0,0" Foreground="#D0D5DD" FontWeight="SemiBold" FontSize="11" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,7">
                <StackPanel>
                    <TextBlock Text="DISCO PRINCIPALE" Style="{StaticResource MetricTitleStyle}" />
                    <TextBlock x:Name="DiskText" Text="-" Style="{StaticResource MetricValueStyle}" />
                    <ProgressBar x:Name="DiskUsageBar" Height="7" Maximum="100" Value="0" Foreground="{StaticResource WarnBrush}" Background="#262A35" />
                    <TextBlock x:Name="DiskFreeText" Text="-" Margin="0,3,0,0" Foreground="#D0D5DD" FontSize="11" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.78*" />
                <ColumnDefinition Width="7" />
                <ColumnDefinition Width="0.72*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="CONTROLLO COMPLETO" FontSize="13" FontWeight="Bold" Foreground="White" />
                    <TextBlock Grid.Row="1" x:Name="DiagnosticStatusText" Text="Pronto." Margin="0,3,0,0" Foreground="#D0D5DD" FontSize="11" />
                    <TextBlock Grid.Row="2" x:Name="DiagnosticDetailText" Text="La diagnostica esegue controlli completi e progressivi." Margin="0,2,0,0" Foreground="#C7CDD8" TextWrapping="Wrap" FontSize="11" />

                    <Grid Grid.Row="3" Margin="0,7,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ProgressBar x:Name="DiagnosticProgressBar"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#262A35" />
                        <TextBlock Grid.Column="1"
                                   x:Name="DiagnosticPercentText"
                                   Text="0%"
                                   Margin="7,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#D0D5DD"
                                   FontSize="11" />

                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
                            <Button x:Name="RunDiagnosticButton" Content="Avvia controllo completo" Style="{StaticResource ActionButtonStyle}" />
                            <Button x:Name="RefreshButton" Content="Aggiorna dashboard" Style="{StaticResource ActionButtonStyle}" />
                            <Button x:Name="OpenLogButton" Content="Apri cartella log" Style="{StaticResource ActionButtonStyle}" />
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Margin="0,7,0,0"
                            Background="#141823"
                            BorderBrush="#2A2D39"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="ESITO RAPIDO"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#B5BDCC"
                                           VerticalAlignment="Center" />

                                <Border Grid.Column="1"
                                        Margin="8,0,4,0"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="#173322">
                                    <TextBlock x:Name="DiagnosticOkCountText"
                                               Text="OK 0"
                                               Foreground="#8EF0B4"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </Border>

                                <Border Grid.Column="2"
                                        Margin="0,0,4,0"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="#3A2D11">
                                    <TextBlock x:Name="DiagnosticWarningCountText"
                                               Text="ATT 0"
                                               Foreground="#FFD36A"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </Border>

                                <Border Grid.Column="3"
                                        Padding="8,3"
                                        CornerRadius="10"
                                        Background="#3C1820">
                                    <TextBlock x:Name="DiagnosticErrorCountText"
                                               Text="ERR 0"
                                               Foreground="#FF9BAF"
                                               FontWeight="Bold"
                                               FontSize="12" />
                                </Border>
                            </Grid>

                            <TextBox Grid.Row="1"
                                     x:Name="DiagnosticSummaryTextBox"
                                     Margin="0,7,0,0"
                                     MinHeight="74"
                                     MaxHeight="92"
                                     Style="{StaticResource OutputTextBoxStyle}"
                                     FontSize="12"
                                     Text="Nessun controllo eseguito." />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="TEMPERATURE" FontSize="13" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="CPU" Style="{StaticResource MetricTitleStyle}" Margin="0,6,0,0" />
                    <TextBlock x:Name="CpuTempText" Text="N/A" Style="{StaticResource MetricValueStyle}" />
                    <TextBlock Text="GPU" Style="{StaticResource MetricTitleStyle}" Margin="0,2,0,0" />
                    <TextBlock x:Name="GpuTempText" Text="N/A" Style="{StaticResource MetricValueStyle}" />
                    <TextBlock Text="SORGENTE" Style="{StaticResource MetricTitleStyle}" Margin="0,2,0,0" />
                    <TextBlock x:Name="SensorSourceText" Text="Non disponibile" Foreground="#D0D5DD" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="11" />
                    <TextBlock x:Name="SensorNoteText" Text="-" Margin="0,2,0,0" Foreground="#C7CDD8" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.84*" />
                <ColumnDefinition Width="9" />
                <ColumnDefinition Width="1.56*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="STATO RAPIDO" FontSize="13" FontWeight="Bold" Foreground="White" />
                    <ScrollViewer Grid.Row="1" Margin="0,5,0,0"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border CornerRadius="10" Background="#141823" Padding="8" Margin="0,0,0,4" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="SystemStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="SystemStatusText" Text="Sistema non verificato" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#141823" Padding="8" Margin="0,0,0,4" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="DiskStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="DiskStatusText" Text="Disco non verificato" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#141823" Padding="8" Margin="0,0,0,4" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="NetworkStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="NetworkStatusText" Text="Rete non verificata" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#141823" Padding="8" Margin="0,0,0,4" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="SecurityStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="SecurityStatusText" Text="Sicurezza non verificata" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#141823" Padding="8" Margin="0,0,0,4" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="RebootStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="RebootStatusText" Text="Riavvio non verificato" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#141823" Padding="8" MinHeight="42">
                                <DockPanel LastChildFill="True">
                                    <Ellipse x:Name="SensorStatusDot" Width="12" Height="12" Fill="#6B7280" Margin="0,1,8,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="SensorStatusText" Text="Sensori non verificati" Foreground="#D0D5DD" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="9" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.ColumnSpan="3" Background="#141823" BorderBrush="#2A2D39" BorderThickness="1" CornerRadius="12" Padding="8" Margin="0,0,0,7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="STATO STRUMENTO" FontSize="12" FontWeight="SemiBold" Foreground="#B5BDCC" />
                                <TextBlock x:Name="ToolStatusText" Text="Nessun comando in esecuzione." Margin="0,3,0,0" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock x:Name="ToolCommandText" Text="Comando: -" Margin="0,3,0,0" Foreground="#D0D5DD" TextWrapping="Wrap" FontSize="12" />
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="ToolStatusBadge" Background="#2A2D39" CornerRadius="10" Padding="9,4" Margin="7,0,0,0" VerticalAlignment="Top">
                                <TextBlock x:Name="ToolStatusBadgeText" Text="IN ATTESA" Foreground="#D0D5DD" FontWeight="Bold" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button x:Name="MenuSystemButton" Content="Sistema" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuStorageButton" Content="Archivio" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuNetworkButton" Content="Rete" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuFirewallButton" Content="Firewall" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuUpdateButton" Content="Update" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuIntegrityButton" Content="Integrita" Style="{StaticResource MenuButtonStyle}" />
                            <Button x:Name="MenuLogButton" Content="Log" Style="{StaticResource MenuButtonStyle}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Grid.Column="2">
                        <Grid x:Name="SystemPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="SystemSettingsButton" Content="Impostazioni sistema" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="NetworkSettingsButton" Content="Impostazioni rete" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="WindowsSecurityButton" Content="Sicurezza Windows" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="InstalledAppsButton" Content="App installate" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="QuickWindowsUpdateButton" Content="Impostazioni update" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="SystemInfoButton" Content="Info sistema" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="TopProcessesButton" Content="Processi attivi" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="CriticalEventsButton" Content="Eventi critici" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="ServicesButton" Content="Servizi" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="PendingRebootButton" Content="Riavvio richiesto" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DriversButton" Content="Driver" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="StartupAppsButton" Content="App avvio" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="ScheduledTasksButton" Content="Attivita pianificate" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="SystemOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="StoragePanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="DiskVolumesButton" Content="Volumi" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="PhysicalDisksButton" Content="Dischi fisici" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="ChkDskButton" Content="CHKDSK info" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="SmartStatusButton" Content="SMART" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="StorageHealthButton" Content="Salute storage" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="StorageOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="NetworkPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="IpConfigButton" Content="IP config" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="NetworkAdaptersButton" Content="Schede di rete" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="PingButton" Content="Ping test" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DnsButton" Content="Test DNS" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="RouteTableButton" Content="Route" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="FlushDnsButton" Content="Flush DNS" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="NetworkOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="FirewallPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="FirewallStatusButton" Content="Stato firewall" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="FirewallRulesButton" Content="Regole firewall" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="FirewallOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="UpdatePanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="WindowsUpdateCheckButton" Content="Controlla aggiornamenti" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="WindowsUpdateHistoryButton" Content="Storico aggiornamenti" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="AntivirusDefinitionsButton" Content="Definizioni AV" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="AntivirusUpdateButton" Content="Aggiorna definizioni AV" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DefenderQuickScanButton" Content="Scansione rapida Defender" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="OpenWindowsUpdateButton" Content="Apri Windows Update" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="WindowsUpdateOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="IntegrityPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button x:Name="SfcScanButton" Content="SFC Scan Now" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="SfcVerifyButton" Content="SFC Verify Only" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DismCheckButton" Content="DISM CheckHealth" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DismScanButton" Content="DISM ScanHealth" Style="{StaticResource ActionButtonStyle}" />
                                <Button x:Name="DismRestoreButton" Content="DISM RestoreHealth" Style="{StaticResource ActionButtonStyle}" />
                            </WrapPanel>
                            <TextBox Grid.Row="1" x:Name="IntegrityOutputTextBox" Margin="0,7,0,0" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>

                        <Grid x:Name="LogPanel" Visibility="Collapsed">
                            <TextBox x:Name="LogTextBox" Style="{StaticResource OutputTextBoxStyle}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="9" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterStatusText"
                       Text="Pronto."
                       Foreground="#D0D5DD"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="2"
                       x:Name="LogPathText"
                       Text="-"
                       Foreground="#98A2B3"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</Window>
